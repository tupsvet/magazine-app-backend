# Скопируйте в .env и при необходимости измените значения.
# Для локального docker compose из этого репозитория подходят значения по умолчанию ниже.

DATABASE_URL=jdbc:postgresql://localhost:5432/magazines_catalog
DATABASE_USER=app
DATABASE_PASSWORD=app_password

JWT_SECRET=change-me-to-long-random-string-at-least-32-chars
JWT_ISSUER=magazines-catalog
JWT_AUDIENCE=magazines-catalog-clients
JWT_REALM=Magazines Catalog API

STORAGE_PATH=./storage
SERVER_PORT=8080
