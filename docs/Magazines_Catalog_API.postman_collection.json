      "name": "Get my profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "       pm.response.to.have.status(200);\r",
              "   });\r",
              "\r",
              "   pm.test(\"Response is UserDto\", function () {\r",
              "       const user = pm.response.json();\r",
              "       pm.expect(user).to.have.property(\"id\");\r",
              "       pm.expect(user).to.have.property(\"email\", \"test@test.com\");\r",
              "       pm.expect(user).to.have.property(\"role\", \"USER\");\r",
              "   });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
