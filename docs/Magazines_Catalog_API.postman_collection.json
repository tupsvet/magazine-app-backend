  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              " const response = pm.response.json();\r",
              "   if (response.token) {\r",
              "       pm.collectionVariables.set(\"token\", response.token);\r",
              "       console.log(\"Token saved:\", response.token.substring(0, 30) + \"...\");\r",
              "   }\r",
              "\r",
              "   pm.test(\"Status code is 200\", function () {\r",
              "       pm.response.to.have.status(200);\r",
              "   });\r",
              "\r",
              "   pm.test(\"Response has token and user\", function () {\r",
              "       pm.expect(response).to.have.property(\"token\");\r",
              "       pm.expect(response).to.have.property(\"user\");\r",
              "       pm.expect(response.user).to.have.property(\"email\", \"test@test.com\");\r",
              "       pm.expect(response.user.role).to.eql(\"USER\");\r",
              "   });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": " {\r\n       \"email\": \"test@test.com\",\r\n       \"password\": \"strongpass123\",\r\n       \"displayName\": \"Test User\"\r\n   }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
